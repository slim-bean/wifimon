// WiFi credentials for connected CSI mode.
// Copy this file to credentials.h and fill in your network passwords.
// credentials.h is gitignored and will not be committed.
//
// Connected mode gives 20-100x better CSI update rates by actively
// generating traffic to the AP. Networks without credentials here
// will fall back to passive promiscuous mode (~3-5 pkt/s).

#pragma once

struct WiFiCredential {
    const char* ssid;
    const char* password;
};

static const WiFiCredential WIFI_CREDENTIALS[] = {
    // {"MyNetwork", "mypassword"},
    // {"OtherNetwork", "otherpassword"},
};

static const int WIFI_CREDENTIALS_COUNT = sizeof(WIFI_CREDENTIALS) / sizeof(WIFI_CREDENTIALS[0]);
